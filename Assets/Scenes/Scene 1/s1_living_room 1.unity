  introLines:
  - Name: SAMPAGUITA
    VoiceSound: {fileID: 8300000, guid: 8070087865f602e4786222f0eb995605, type: 3}
    DialogueToPrint: Here you go Nanay!
    LettersPerSecond: 15
  - Name: NANAY
    VoiceSound: {fileID: 8300000, guid: a62f837488a46bf4391e0821a77ababd, type: 3}
    DialogueToPrint: "Thank you dear.\r"
    LettersPerSecond: 15
  - Name: 
    VoiceSound: {fileID: 8300000, guid: 54cb851ce76ac6b4b9637e09b6a65234, type: 3}
    DialogueToPrint: "Thanks to SAMPAGUITA\u2019s help, her NANAY managed to complete
      the wreath. SAMPAGUITA was amazed by her NANAY\u2019S work.\r"
    LettersPerSecond: 15
  - Name: SAMPAGUITA
    VoiceSound: {fileID: 8300000, guid: 8070087865f602e4786222f0eb995605, type: 3}
    DialogueToPrint: Woah! This looks so pretty!
    LettersPerSecond: 15
